generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm, vector]
}

// A company that scraped jobs belong to.
model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  jobs      Job[]
}

// One scraped job posting — the unit the UI shows.
// Rounds are NOT stored; they are parsed at read time from focusRoundPattern (split on '+').
model Job {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobTitle            String
  site                String?
  location            String?
  roleCategory        String?
  roleType            String?
  workMode            String?
  requiredSkills      String?
  otherSkillsNotes    String?
  educationRequirement String?
  roleSummary         String?
  keyResponsibilities String?

  // Original posting URL and the complete scraped job description text.
  sourceUrl          String?
  fullJobDescription String?

  // Fixed 4-round interview structure. Each holds ';'-separated key competencies/topics
  // for that round, precomputed in the source JobPostingsV2 table.
  roundScreening   String?
  roundBehavioural String?
  roundTechnical   String?
  roundCultureFit  String?

  // '+'-separated round pattern, kept so the listing/search layer keeps working;
  // the importer now populates it with the fixed "Screening + Behavioural + Technical + Culture fit".
  focusRoundPattern String
  // ';'-separated "Name - description" detail, kept for round descriptions.
  focusRounds       String?

  // Legacy cached LLM-derived competencies JSON (no longer populated; rounds carry competencies now).
  competencies      String?

  experienceMinYears  Int?
  experienceMaxYears  Int?
  salaryInrMinPerYear Int?
  salaryInrMaxPerYear Int?

  // 512-dim vector from Bedrock Titan Text Embeddings V2 over a composite of title+roleType+summary+skills.
  // Queried via $queryRaw; the HNSW index DDL lives in prisma/migrations/0_init.
  embedding Unsupported("vector(512)")?
  sourceRowHash   String    @unique
  loadedAt        DateTime?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  skills       JobSkill[]
  capabilities JobCapability[]

  @@index([companyId])
  @@index([experienceMinYears, experienceMaxYears])
  // HNSW cosine ANN index; real DDL (USING hnsw + vector_cosine_ops) lives in
  // prisma/migrations/0_init. Declared here so Prisma Migrate doesn't drop it.
  @@index([embedding], map: "job_embedding_hnsw")
}

// Deduped skill catalog: one row per distinct normalized skill token across all
// jobs. The vector is embed(gloss) — never embed(token); bare-token Titan
// embeddings are not separable (see docs/ARCHITECTURE.md "Why glosses are mandatory").
model Skill {
  id        String     @id @default(cuid())
  token     String     @unique // normalized: lowercased, [^a-z0-9] stripped
  label     String // display name as first seen
  gloss     String // LLM one-liner; the embedding input
  embedding Unsupported("vector(512)")?
  createdAt DateTime   @default(now())
  jobs      JobSkill[]

  // HNSW cosine ANN index; real DDL added by hand in the migration.
  @@index([embedding], map: "skill_embedding_hnsw")
}

// Thin join: which jobs require which catalog skills. No vector — coverage is
// set membership against the per-search resolved coveredSkillIds.
model JobSkill {
  jobId   String
  skillId String
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id])

  @@id([jobId, skillId])
  @@index([skillId])
}

// One responsibility/capability statement per row, built at import from the
// union of keyResponsibilities, roleSummary, and roundTechnical (requiredSkills
// is deliberately excluded — skills own 65% of the blend already). Candidate
// project vectors are compared against these via capped ANN top-K.
model JobCapability {
  id        String @id @default(cuid())
  jobId     String
  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  text      String
  embedding Unsupported("vector(512)")?

  @@index([jobId])
  // HNSW cosine ANN index; real DDL added by hand in the migration.
  @@index([embedding], map: "job_capability_embedding_hnsw")
}
