generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm, vector]
}

// A company that scraped jobs belong to.
model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  jobs      Job[]
}

// One scraped job posting — the unit the UI shows.
// Rounds are NOT stored; they are parsed at read time from focusRoundPattern (split on '+').
model Job {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobTitle            String
  site                String?
  location            String?
  roleCategory        String?
  roleType            String?
  workMode            String?
  requiredSkills      String?
  otherSkillsNotes    String?
  educationRequirement String?
  roleSummary         String?
  keyResponsibilities String?

  // Original posting URL and the complete scraped job description text.
  sourceUrl          String?
  fullJobDescription String?

  // Fixed 4-round interview structure. Each holds ';'-separated key competencies/topics
  // for that round, precomputed in the source JobPostingsV2 table.
  roundScreening   String?
  roundBehavioural String?
  roundTechnical   String?
  roundCultureFit  String?

  // '+'-separated round pattern, kept so the listing/search layer keeps working;
  // the importer now populates it with the fixed "Screening + Behavioural + Technical + Culture fit".
  focusRoundPattern String
  // ';'-separated "Name - description" detail, kept for round descriptions.
  focusRounds       String?

  // Legacy cached LLM-derived competencies JSON (no longer populated; rounds carry competencies now).
  competencies      String?

  experienceMinYears  Int?
  experienceMaxYears  Int?
  salaryInrMinPerYear Int?
  salaryInrMaxPerYear Int?

  // 512-dim vector from Bedrock Titan Text Embeddings V2 over a composite of title+roleType+summary+skills.
  // Queried via $queryRaw; HNSW index lives in prisma/db-init.sql.
  embedding Unsupported("vector(512)")?

  sourceRowHash   String    @unique
  loadedAt        DateTime?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([experienceMinYears, experienceMaxYears])
}
